# PostgreSQL — use the SAME connection string as meavo-gateway
DATABASE_URL="postgresql://user:password@localhost:5432/meavo_gateway"

# Neon on Vercel often auto-creates this instead of DATABASE_URL.
# Use it for local db:push / db:seed against production (see scripts/setup-production-db.sh).
# DATABASE_URL_UNPOOLED="postgresql://..."

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google sign-in (optional — button hidden if unset)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated emails that get admin access on sign-in
ADMIN_EMAILS="you@company.com"

# Initial admin password (used by meavo-gateway db:seed only)
ADMIN_PASSWORD="change-me-in-production"

# Slack incoming webhook URL for manager notifications (optional)
# Production only — do not set on Vercel Preview.
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Preview/staging: use a separate Neon database for Vercel Preview deployments.
# See README "Preview staging setup" for full instructions.
