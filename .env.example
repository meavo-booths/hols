# Local development — use SQLite via a local Postgres Docker container or Neon dev branch.
# Production on Vercel requires PostgreSQL (Neon is recommended).
DATABASE_URL="postgresql://user:password@localhost:5432/vacation_tracker"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Comma-separated emails that get admin access on sign-in
ADMIN_EMAILS="you@company.com"

# Initial admin password (used by db:seed only)
ADMIN_PASSWORD="change-me-in-production"
