generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  ADMIN
  USER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum Company {
  MEAVO
  OA
}

enum ContractType {
  FTE
  FREELANCE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Shared with meavo-gateway (same DATABASE_URL)
model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  systemRole    SystemRole @default(USER)
  hrAccess      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts         Account[]
  sessions         Session[]
  teamMemberships  TeamMember[]
  cardAccess       ToolCardAccess[]
  vacationRequests VacationRequest[] @relation("Requester")
  reviewedRequests VacationRequest[] @relation("Reviewer")
  allowances       UserAllowance[]
  employee         Employee?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id              String       @id @default(cuid())
  name            String       @unique
  color           String       @default("#EEDCDC")
  yearlyAllowance Int          @default(25)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  members         TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model ToolCard {
  id          String           @id @default(cuid())
  name        String
  description String
  url         String
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  access      ToolCardAccess[]
}

model ToolCardAccess {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card ToolCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

// Vacation Tracker–specific
model UserAllowance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  days      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model VacationRequest {
  id           String        @id @default(cuid())
  userId       String
  startDate    DateTime
  endDate      DateTime
  days         Float
  note         String?
  status       RequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User  @relation("Requester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model Employee {
  id        String       @id @default(cuid())
  userId    String       @unique
  company   Company
  contract  ContractType
  startDate DateTime     @db.Date
  endDate   DateTime?    @db.Date
  role      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  fileName   String
  mimeType   String
  storageKey String
  uploadedBy String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model NotificationOutbox {
  id             String             @id @default(cuid())
  sourceApp      String
  eventType      String
  idempotencyKey String?            @unique
  payload        Json
  status         NotificationStatus @default(PENDING)
  attempts       Int                @default(0)
  lastError      String?
  scheduledFor   DateTime           @default(now())
  sentAt         DateTime?
  createdAt      DateTime           @default(now())

  deliveries NotificationDelivery[]

  @@index([status, scheduledFor])
}

model NotificationDelivery {
  id              String             @id @default(cuid())
  outboxId        String
  recipientEmail  String
  recipientUserId String?
  subject         String
  resendMessageId String?
  status          NotificationStatus @default(PENDING)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime           @default(now())

  outbox NotificationOutbox @relation(fields: [outboxId], references: [id], onDelete: Cascade)

  @@index([outboxId])
  @@index([createdAt])
}
